# ============================================================
# OpenSTA timing analysis script
# Project : ic_study
# Top     : led_test
# Function: Read netlist + Liberty + SDC, then report timing
# ============================================================

set TOP     led_test
set LIB     ../libs/Nangate45/NangateOpenCellLibrary_typical.lib
set NETLIST led_test_netlist.v
set SDC     constraints.sdc

# ------------------------------------------------------------
# 1. Read timing library
# ------------------------------------------------------------
read_liberty $LIB

# ------------------------------------------------------------
# 2. Read gate-level netlist generated by Yosys
# ------------------------------------------------------------
read_verilog $NETLIST

# ------------------------------------------------------------
# 3. Link top design
# ------------------------------------------------------------
link_design $TOP

# ------------------------------------------------------------
# 4. Read SDC constraints
# ------------------------------------------------------------
read_sdc $SDC

# ------------------------------------------------------------
# 5. Basic design/timing checks
# ------------------------------------------------------------
check_setup
#check_timing

# ------------------------------------------------------------
# 6. Report setup timing paths
# ------------------------------------------------------------
puts "\n================ SETUP TIMING REPORT ================\n"
report_checks \
    -path_delay max \
    -fields {slew cap input_pins nets fanout} \
    -digits 4 \
    -group_count 5

# ------------------------------------------------------------
# 7. Report hold timing paths
# ------------------------------------------------------------
puts "\n================ HOLD TIMING REPORT =================\n"
report_checks \
    -path_delay min \
    -fields {slew cap input_pins nets fanout} \
    -digits 4 \
    -group_count 5

# ------------------------------------------------------------
# 8. Report summary
# ------------------------------------------------------------
puts "\n================ TIMING SUMMARY ======================\n"

report_checks \
    -path_delay min \
    -slack_max 0.0 \
    -fields {slew cap input_pins nets fanout} \
    -digits 4 \
    -group_count 20



puts "\nWorst setup slack:"
report_worst_slack -max

puts "\nWorst hold slack:"
report_worst_slack -min

puts "\nTotal negative setup slack:"
report_tns -max

puts "\nTotal negative hold slack:"
report_tns -min

puts "\n================ STA FINISHED ========================\n"