# ============================================================
# UART_LOOPBACK timing constraints
# ============================================================

# 1. System clock: 50 MHz, period = 20 ns
create_clock -name sys_clk -period 20.000 [get_ports sys_clk]

# 2. Clock uncertainty
set_clock_uncertainty -setup 0.300 [get_clocks sys_clk]
set_clock_uncertainty -hold  0.100 [get_clocks sys_clk]

# 3. Asynchronous reset
# sys_rst_n is async active-low reset.
set_false_path -from [get_ports sys_rst_n]

# 4. Asynchronous UART RX input
# uart_rxd is an external asynchronous serial input.
# It is synchronized inside uart_rx.
set_false_path -from [get_ports uart_rxd]

# 5. UART TX output
# uart_txd is generated by internal sys_clk logic.
# For learning-level pre-layout STA, give it an output delay model.
set_output_delay -max 3.000 -clock [get_clocks sys_clk] [get_ports uart_txd]
set_output_delay -min 0.000 -clock [get_clocks sys_clk] [get_ports uart_txd]

# 6. Output load
set_load 0.050 [get_ports uart_txd]

# 7. Design rule constraints
set_max_transition 0.5 [current_design]
set_max_capacitance 1.0 [current_design]
