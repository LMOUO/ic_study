puts "============================================================"

# ============================================================
# ============================================================
# ============================================================

#read_liberty $LIB
read_verilog $RTL

synth -top $TOP

dfflibmap -liberty $LIB
abc -liberty $LIB

opt
clean

write_verilog $NETLIST

stat -liberty $LIB