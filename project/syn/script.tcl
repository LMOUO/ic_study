yosys -import

# ============================================================
# ============================================================
# ============================================================
# DC
set TOP     $::env(TOP)
set RTL     $::env(RTL)
set NETLIST $::env(NETLIST)
set LIB     $::env(LIB)

puts "============================================================"
puts "YOSYS SYNTHESIS"
puts "TOP     = $TOP"
puts "RTL     = $RTL"
